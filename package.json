{
  "name": "@starredev/schedule-x-plugins",
  "license": "MIT",
  "version": "1.6.4",
  "main": "./dist/schedule-x-plugin.umd.js",
  "module": "./dist/schedule-x-plugin.mjs",
  "types": "./dist/types/index.d.ts",
  "type": "module",
  "engines": {
    "node": "22",
    "npm": "10"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,vue --report-unused-disable-directives --max-warnings 5",
    "lint:fix": "eslint . --fix --ext ts,vue --report-unused-disable-directives --max-warnings 5",
    "format": "prettier --write .",
    "test": "cypress run",
    "build:publish": "npm run build && npm publish",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "vue": "^3"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "release-it": "^20.2.0",
    "sass": "^1.69.5",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-pages": "^0.33.3",
    "vue-tsc": "^3.3.4"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "uuid": "^14.0.0"
  }
